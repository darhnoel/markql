    "note": "missing projection"
  },
  {
    "query": "SELECT div doc",
    "expected_verdict": "reject",
    "note": "missing FROM keyword"
  },
  {
    "query": "FROM doc SELECT div",
    "expected_verdict": "reject",
    "note": "wrong clause order"
  },
  {
    "query": "SELECT div FROM",
