== stmt 1/1 ==
[{"ingredient":"ត្រី ១គីឡូក្រាម"},{"ingredient":"គល់ស្លឹកគ្រៃ ៤គល់"},{"ingredient":"ម្ទេសប្លោកក្រៀម ៣ផ្លែ"},{"ingredient":"ល្មៀត ១ដុំតូចល្មម"},{"ingredient":"សម្បកក្រូចសើច ១ចំណិត ឬស្លឹកក្រូចសើច ៣"},{"ingredient":"សន្លឹកអំបិល កន្លះស្លាបព្រាបាយ"},{"ingredient":"ក្រសាំង ៤ផ្លែ (តាមផ្លែតូច ឬធំ)"},{"ingredient":"ប្រហុក ៣០ក្រាម"},{"ingredient":"ម្ទេសប្លោកស្រស់ ២ផ្លែ"},{"ingredient":"ទឹកត្រី ១ស្លាបព្រាបាយ"},{"ingredient":"ខ្ទឹមស ១ដុំ"},{"ingredient":"ប៊ីចេង ១ស្លាបព្រាកាផែ"},{"ingredient":"ស្ករត្នោត កន្លះស្លាបព្រាបាយ"},{"ingredient":"រំដេង ១ដុំតូចល្មម ។"}]
